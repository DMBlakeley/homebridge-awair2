{
  "compilerOptions": {
    "ignoreDeprecations": "7.0",
    "target": "ES2018",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": [
      "ES2015",
      "ES2016",
      "ES2017",
      "ES2018",
      "dom"
    ],
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*"
  ]
}
